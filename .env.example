# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DATABASE=childsense_db

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:19000

# Storage Configuration (Supabase Buckets)
SUPABASE_BUCKET_PROFILES=profile-images
SUPABASE_BUCKET_CHILD_PROFILES=child-profile-images
SUPABASE_BUCKET_ALERTS=alert-media
SUPABASE_BUCKET_FACE_PHOTOS=face-photos

# ML Service Configuration — URL the FastAPI backend uses to reach ml_api (server-side).
# Same machine: prefer http://127.0.0.1:8001 on Windows (your LAN IP may not route back to localhost).
ML_SERVICE_URL=http://127.0.0.1:8001
FACE_MATCH_THRESHOLD=0.6

# Application Settings
ENVIRONMENT=development
DEBUG=True
